{
  "name": "@jogi/extract",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./normalize": {
      "types": "./dist/normalize.d.ts",
      "import": "./dist/normalize.mjs",
      "require": "./dist/normalize.js"
    },
    "./liquidacion": {
      "types": "./dist/liquidacion/index.d.ts",
      "import": "./dist/liquidacion/index.mjs",
      "require": "./dist/liquidacion/index.js"
    },
    "./liquidacion/types": {
      "types": "./dist/liquidacion/types.d.ts",
      "import": "./dist/liquidacion/types.mjs",
      "require": "./dist/liquidacion/types.js"
    },
    "./liquidacion/resolve": {
      "types": "./dist/liquidacion/resolve.d.ts",
      "import": "./dist/liquidacion/resolve.mjs",
      "require": "./dist/liquidacion/resolve.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsx tests/compile-lexicon.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "playground": "tsx dev/server.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "corpus": "tsx tests/corpus.ts",
    "groundtruth": "tsx tests/groundtruth.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@google/genai": "^0.9.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "dotenv": "^16.0.0",
    "js-yaml": "^4.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
